{
  "manifest_version": 3,
  "name": "DualSubs",
  "version": "1.0.0",
  "description": "Real-time dual subtitles (original + translated) for YouTube and Udemy",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://api.mymemory.translated.net/*",
    "https://translation.googleapis.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://www.udemy.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
